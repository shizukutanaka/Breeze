{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/core/tauri-config-schema/schema.json",
  "productName": "Breeze",
  "version": "3.6.0",
  "identifier": "com.breeze.messenger",
  "build": {
    "frontendDist": "../../",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src 'self' https: wss: stun: turn:; img-src 'self' blob: data: https:; media-src 'self' blob:; worker-src 'self' blob:"
    },
    "windows": [
      {
        "title": "Breeze",
        "width": 960,
        "height": 720,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Breeze"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "P2P encrypted messenger",
    "longDescription": "Breeze is a P2P encrypted messenger. No phone number. No email. Zero dependencies. Single HTML file deployed on Cloudflare Pages.",
    "copyright": "Copyright © 2026 Breeze",
    "externalBin": [],
    "linux": {
      "appimage": { "bundleMediaFramework": false },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "desktopTemplate": "breeze.desktop"
      },
      "rpm": {
        "depends": ["webkit2gtk4.1", "gtk3"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [],
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English", "Japanese"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": { "schemes": ["breeze"] },
      "mobile": { "schemes": ["breeze"] }
    },
    "notification": { "permissionAllowed": true },
    "global-shortcut": {}
  }
}
