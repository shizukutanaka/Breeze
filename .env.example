# ══════════════════════════════════════════════════════════
# Breeze Messenger — Environment Variables
# Copy to Cloudflare Pages > Settings > Environment Variables
# or use: wrangler secret put <KEY>
# ══════════════════════════════════════════════════════════

# ─── Required: KV Binding ────────────────────────────────
# Create via: wrangler kv:namespace create KV
# Then bind in Pages > Settings > Functions > KV namespace bindings
# Name: KV
# KV=<bound automatically>

# ─── Billing (Stripe) — $0 until first sale ──────────────
# Create account: https://dashboard.stripe.com/register
# Create 3 products with recurring prices, then set IDs below
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_LITE=price_...        # $0.99/month — 2 accounts
# STRIPE_PRICE_PLUS=price_...        # $5.99/month — 4 accounts
# STRIPE_PRICE_PRO=price_...         # $19.99/month — unlimited

# ─── TURN Server (NAT traversal) ─────────────────────────
# Option A: Cloudflare Calls (recommended, $0.05/GB)
#   Create at: Dashboard > Calls > Create > TURN App
# TURN_KEY_ID=<your-turn-key-id>
# TURN_KEY_API_TOKEN=<your-turn-api-token>
#
# Option B: Custom HMAC (Coturn self-hosted)
# TURN_URL=turn:your-server:3478
# TURN_SECRET=your-hmac-secret
#
# Option C: Static credentials (metered.ca, twilio, etc.)
# TURN_URL=turn:relay.metered.ca:80
# TURN_USERNAME=your-username
# TURN_CREDENTIAL=your-credential
#
# Option D: No config needed → auto-falls to free Open Relay (20GB/month)

# ─── Web Push Notifications ──────────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BM...
# VAPID_PRIVATE_KEY=<base64-private-key>

# ─── AI (optional — all have free tiers) ─────────────────
# Priority: Anthropic → OpenAI → Groq
# Groq recommended for $0: https://console.groq.com (free tier)
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.1-70b-versatile
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
#
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com  # or compatible API

# ─── Translation (optional — MyMemory is free fallback) ──
# DEEPL_API_KEY=...                   # DeepL Pro/Free
# GOOGLE_TRANSLATE_KEY=...            # Google Cloud Translation
# TRANSLATE_URL=https://libretranslate.example.com  # Self-hosted

# ══════════════════════════════════════════════════════════
# $0/month deployment: Set NOTHING above.
# - KV binding is the only requirement (free)
# - TURN auto-falls to free Open Relay
# - Translation auto-falls to free MyMemory
# - Billing disabled (all users get Free plan)
# - AI disabled (local extractive summarizer still works)
# - Push notifications disabled
# ══════════════════════════════════════════════════════════
